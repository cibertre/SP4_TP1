<!DOCTYPE html>

<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Agregar Superhéroe</title>

    <link rel="stylesheet"
          href="/css/styles.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

</head>

<body>

<%- include('partials/header') %>
<main class="main-content">
<div class="container">

    <div class="form-card">
        <h2>➕ Nuevo Superhéroe</h2>
        <% if (errores.length > 0) { %>

  <ul class="error-list">

    <% errores.forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>

  </ul>

<% } %>

        <form action="/heroes/agregar" method="POST">

            <div class="form-group">
                <label>Nombre Héroe</label>
                <input name="nombreSuperHeroe" value="<%= oldData.nombreSuperHeroe || '' %>" required>
            </div>

            <div class="form-group">
                <label>Nombre Real</label>
                <input name="nombreReal" value="<%= oldData.nombreReal || '' %>" required>
            </div>

            <div class="form-group">
                <label>Edad</label>
                <input type="number" name="edad" min="1" value="<%= oldData.edad || '' %>" required>
            </div>

            <div class="form-group">
                <label>Planeta</label>
                <input name="planetaOrigen" value="<%= oldData.planetaOrigen || '' %>">
            </div>

            <div class="form-group">
                <label>Poderes</label>
                <input name="poderes" value="<%= oldData.poderes || '' %>" placeholder="volar, fuerza, rayos">
            </div>
            <div class="form-group">
                 <label>Debilidad</label>
                <input name="debilidad" value="<%= oldData.debilidad || '' %>" placeholder="Kryptonita, fuego, magia..."
    >
            </div>
            <div class="form-group">
                 <label>Creador</label>
               <input type="text" name="creador" value="<%= oldData.creador || '' %>"
        placeholder="Stan Lee, Bob Kane..."
    >
</div>

            <button class="btn btn-add">Guardar</button>
            <a href="/heroes" class="btn btn-back">Volver</a>

        </form>
    </div>

</div>
</main>
<%- include('partials/footer') %>
</body>
</html>